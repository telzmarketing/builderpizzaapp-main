# ── Banco de dados ────────────────────────────────────────────────────────────
# Formato: postgresql://usuario:senha@host:porta/nome_banco
# Substitua "minhaloja" e "minhaloja_user" pelos valores gerados pelo setup_database.sh
# (ou consulte o arquivo db_connection.txt criado pelo script)
DATABASE_URL=postgresql://minhaloja_user:SENHA@localhost:5432/minhaloja

# ── Aplicação ─────────────────────────────────────────────────────────────────
APP_NAME=PizzaApp API
APP_VERSION=1.0.0
DEBUG=false

# ── CORS (origens permitidas, separadas por vírgula) ─────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Autenticação admin (JWT) ──────────────────────────────────────────────────
# Gere uma chave segura em produção: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=TROQUE_POR_CHAVE_GERADA_COM__python3_-c_import_secrets_print_secrets.token_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── Conta admin inicial (criada no primeiro boot do banco) ────────────────────
# Troque antes de iniciar pela primeira vez. Não pode ser vazio em produção.
ADMIN_EMAIL=admin@minhaloja.com.br
ADMIN_NAME=Administrador
ADMIN_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI

# ── Gateway de pagamento ──────────────────────────────────────────────────────
# "mock" para testes locais | "stripe" | "mercadopago"
PAYMENT_GATEWAY=mock
PAYMENT_SECRET_KEY=sua_chave_secreta_aqui
PAYMENT_WEBHOOK_SECRET=sua_chave_webhook_aqui

# ── Fidelidade ────────────────────────────────────────────────────────────────
POINTS_PER_REAL=1.0      # pontos por R$ gasto
DELIVERY_POINTS=10       # bônus por pedido entregue
